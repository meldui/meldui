{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off"
  },
  "rules": {
    "eslint/no-unused-vars": "error",
    "typescript/no-explicit-any": "warn",
    "import/no-duplicates": "error"
  },
  "overrides": [
    {
      "files": ["**/*.vue"],
      "rules": {
        "vue/require-default-export": "warn"
      }
    }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.turbo/**",
    "**/storybook-static/**",
    "**/.astro/**",
    "**/demos/**",
    "**/packages/a2ui/src/schema/**",
    "**/packages/a2ui/src/catalog/functions.json",
    "**/packages/a2ui/src/catalog/theme-schema.json",
    "**/packages/a2ui/scripts/*.fixture.json"
  ]
}
