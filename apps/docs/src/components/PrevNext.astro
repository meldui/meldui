---
import { navigation, flattenNav } from '../data/navigation'

const currentPath = Astro.url.pathname
const flat = flattenNav(navigation)

const currentIndex = flat.findIndex(
  (item) => item.href === currentPath || item.href + '/' === currentPath
)

const prev = currentIndex > 0 ? flat[currentIndex - 1] : null
const next = currentIndex < flat.length - 1 ? flat[currentIndex + 1] : null
---

{
  (prev || next) && (
    <div class="mt-12 flex items-center justify-between border-t border-border pt-6">
      {prev ? (
        <a
          href={prev.href}
          class="group flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          <svg
            class="size-4 transition-transform group-hover:-translate-x-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15.75 19.5 8.25 12l7.5-7.5"
            />
          </svg>
          {prev.title}
        </a>
      ) : (
        <div />
      )}
      {next ? (
        <a
          href={next.href}
          class="group flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          {next.title}
          <svg
            class="size-4 transition-transform group-hover:translate-x-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m8.25 4.5 7.5 7.5-7.5 7.5"
            />
          </svg>
        </a>
      ) : (
        <div />
      )}
    </div>
  )
}
