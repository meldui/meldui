{
  "name": "docs",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm prepare-assets && pnpm prepare-catalog && astro dev",
    "build": "pnpm prepare-assets && pnpm prepare-catalog && pnpm generate-a2ui-reference && tsx scripts/generate-llms.ts && astro build && pagefind --site dist",
    "generate-llms": "tsx scripts/generate-llms.ts",
    "generate-a2ui-reference": "tsx scripts/generate-a2ui-reference.ts",
    "prepare-catalog": "tsx scripts/prepare-catalog.ts",
    "preview": "astro preview",
    "prepare-assets": "node -e \"import('node:fs/promises').then(async fs => { await fs.mkdir('public', { recursive: true }); await fs.copyFile('./node_modules/@embedpdf/pdfium/dist/pdfium.wasm', 'public/pdfium.wasm') }).catch(e => { console.warn('[docs] could not copy pdfium.wasm:', e.message); process.exit(0) })\""
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/sitemap": "^3.3.1",
    "@astrojs/vue": "^5.0.6",
    "@incremark/theme": "^0.3.10",
    "@incremark/vue": "^0.3.10",
    "@internationalized/date": "^3.10.0",
    "@meldui/a2ui": "workspace:*",
    "@meldui/charts-vue": "workspace:*",
    "@meldui/tabler-vue": "workspace:*",
    "@meldui/vue": "workspace:*",
    "@tanstack/vue-table": "^8.21.3",
    "astro": "^5.10.1",
    "shiki": "^3.0.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.0",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@embedpdf/core": "^2.14.2",
    "@embedpdf/engines": "^2.14.2",
    "@embedpdf/models": "^2.14.2",
    "@embedpdf/pdfium": "^2.14.2",
    "@embedpdf/plugin-annotation": "^2.14.2",
    "@embedpdf/plugin-attachment": "^2.14.2",
    "@embedpdf/plugin-bookmark": "^2.14.2",
    "@embedpdf/plugin-document-manager": "^2.14.2",
    "@embedpdf/plugin-export": "^2.14.2",
    "@embedpdf/plugin-form": "^2.14.2",
    "@embedpdf/plugin-fullscreen": "^2.14.2",
    "@embedpdf/plugin-history": "^2.14.2",
    "@embedpdf/plugin-interaction-manager": "^2.14.2",
    "@embedpdf/plugin-pan": "^2.14.2",
    "@embedpdf/plugin-redaction": "^2.14.2",
    "@embedpdf/plugin-render": "^2.14.2",
    "@embedpdf/plugin-rotate": "^2.14.2",
    "@embedpdf/plugin-scroll": "^2.14.2",
    "@embedpdf/plugin-search": "^2.14.2",
    "@embedpdf/plugin-selection": "^2.14.2",
    "@embedpdf/plugin-signature": "^2.14.2",
    "@embedpdf/plugin-spread": "^2.14.2",
    "@embedpdf/plugin-stamp": "^2.14.2",
    "@embedpdf/plugin-thumbnail": "^2.14.2",
    "@embedpdf/plugin-tiling": "^2.14.2",
    "@embedpdf/plugin-viewport": "^2.14.2",
    "@embedpdf/plugin-zoom": "^2.14.2",
    "@tailwindcss/vite": "^4.1.17",
    "pagefind": "^1.3.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
