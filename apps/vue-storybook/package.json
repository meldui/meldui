{
  "name": "vue-storybook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm prepare-assets && storybook dev -p 6006",
    "build": "pnpm prepare-assets && storybook build",
    "storybook": "pnpm prepare-assets && storybook dev -p 6006",
    "build-storybook": "pnpm prepare-assets && storybook build",
    "prepare-assets": "node -e \"import('node:fs/promises').then(async fs => { await fs.mkdir('public', { recursive: true }); await fs.copyFile('./node_modules/@embedpdf/pdfium/dist/pdfium.wasm', 'public/pdfium.wasm') }).catch(e => { console.warn('[storybook] could not copy pdfium.wasm:', e.message); process.exit(0) })\""
  },
  "dependencies": {
    "@incremark/theme": "^0.3.10",
    "@internationalized/date": "^3.10.0",
    "@meldui/a2ui": "workspace:*",
    "@meldui/charts-vue": "workspace:*",
    "@meldui/tabler-vue": "workspace:*",
    "@meldui/vue": "workspace:*",
    "@vee-validate/zod": "^4.15.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.0",
    "vue-sonner": "^2.0.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@embedpdf/core": "^2.14.2",
    "@embedpdf/engines": "^2.14.2",
    "@embedpdf/models": "^2.14.2",
    "@embedpdf/pdfium": "^2.14.2",
    "@embedpdf/plugin-annotation": "^2.14.2",
    "@embedpdf/plugin-bookmark": "^2.14.2",
    "@embedpdf/plugin-commands": "^2.14.2",
    "@embedpdf/plugin-document-manager": "^2.14.2",
    "@embedpdf/plugin-export": "^2.14.2",
    "@embedpdf/plugin-fullscreen": "^2.14.2",
    "@embedpdf/plugin-history": "^2.14.2",
    "@embedpdf/plugin-interaction-manager": "^2.14.2",
    "@embedpdf/plugin-pan": "^2.14.2",
    "@embedpdf/plugin-print": "^2.14.2",
    "@embedpdf/plugin-render": "^2.14.2",
    "@embedpdf/plugin-rotate": "^2.14.2",
    "@embedpdf/plugin-scroll": "^2.14.2",
    "@embedpdf/plugin-search": "^2.14.2",
    "@embedpdf/plugin-selection": "^2.14.2",
    "@embedpdf/plugin-spread": "^2.14.2",
    "@embedpdf/plugin-thumbnail": "^2.14.2",
    "@embedpdf/plugin-tiling": "^2.14.2",
    "@embedpdf/plugin-viewport": "^2.14.2",
    "@embedpdf/plugin-zoom": "^2.14.2",
    "@mdx-js/react": "^3.1.1",
    "@storybook/addon-a11y": "^10.0.8",
    "@storybook/addon-docs": "^10.0.8",
    "@storybook/addon-links": "^10.0.8",
    "@storybook/vue3-vite": "^10.0.8",
    "@tailwindcss/vite": "^4.1.17",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-vue": "^6.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.0.8",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.3.0",
    "vite": "8.0.0-beta.10"
  }
}
