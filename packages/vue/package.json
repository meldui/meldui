{
  "name": "@meldui/vue",
  "version": "0.3.5",
  "description": "MeldUI Vue component library built on shadcn-vue",
  "keywords": [
    "components",
    "design-system",
    "shadcn",
    "tailwind",
    "vue"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/meldui/meldui.git",
    "directory": "packages/vue"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    },
    "./themes/default": {
      "style": "./dist/themes/default.css",
      "import": "./dist/themes/default.css",
      "require": "./dist/themes/default.css",
      "default": "./dist/themes/default.css"
    },
    "./styles": {
      "style": "./dist/esm/vue.css",
      "import": "./dist/esm/vue.css",
      "require": "./dist/esm/vue.css",
      "default": "./dist/esm/vue.css"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit"
  },
