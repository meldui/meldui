{
  "name": "@meldui/editor",
  "version": "0.0.0",
  "description": "MeldUI Vue rich-text editor built on TipTap",
  "keywords": [
    "design-system",
    "editor",
    "prosemirror",
    "rich-text",
    "tiptap",
    "vue"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/meldui/meldui.git",
    "directory": "packages/editor"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    },
    "./styles": {
      "style": "./dist/esm/editor.css",
      "import": "./dist/esm/editor.css",
      "require": "./dist/esm/editor.css",
      "default": "./dist/esm/editor.css"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@tiptap/core": "^3.22.2",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-mention": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/extension-table": "^3.22.2",
    "@tiptap/extension-table-cell": "^3.22.2",
    "@tiptap/extension-table-header": "^3.22.2",
    "@tiptap/extension-table-of-contents": "^3.22.2",
    "@tiptap/extension-table-row": "^3.22.2",
    "@tiptap/extension-task-item": "^3.22.2",
    "@tiptap/extension-task-list": "^3.22.2",
    "@tiptap/extension-text-align": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@tiptap/suggestion": "^3.22.2",
    "@tiptap/vue-3": "^3.22.2",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.5.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.3.0",
    "vite": "8.0.0-beta.10",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "@meldui/charts-vue": "workspace:*",
    "@meldui/tabler-vue": "workspace:*",
    "@meldui/vue": "workspace:*",
    "vue": "^3.5.0"
  }
}
