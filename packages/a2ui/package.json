{
  "name": "@meldui/a2ui",
  "version": "0.1.0",
  "description": "MeldUI A2UI catalog — a portable, framework-agnostic catalog contract that lets any A2UI agent target MeldUI components",
  "keywords": [
    "a2ui",
    "agent-ui",
    "catalog",
    "design-system",
    "generative-ui",
    "meldui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/meldui/meldui.git",
    "directory": "packages/a2ui"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./catalog": {
      "default": "./dist/schema/meldui-v1.catalog.json"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm generate-catalog && vite build",
    "typecheck": "tsc --noEmit",
    "generate-catalog": "tsx scripts/generate-catalog.ts",
    "validate-catalog": "tsx scripts/validate-catalog.ts"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "8.0.0-beta.10",
    "vite-plugin-dts": "^4.5.4"
  }
}
